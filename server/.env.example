# Configurazione API — Il Faro 1 di Canicattì
# Copia in .env e adatta i valori.

# Porta del server API
PORT=4000

# Origine del frontend autorizzata a chiamare l'API (CORS).
# In sviluppo tipicamente http://127.0.0.1:5173 ; in produzione l'URL del sito.
FRONTEND_ORIGIN=*

# Connessione PostgreSQL (in alternativa usare DATABASE_URL)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=faro
PGPASSWORD=faro
PGDATABASE=faro_canicatti
# DATABASE_URL=postgres://faro:faro@127.0.0.1:5432/faro_canicatti
